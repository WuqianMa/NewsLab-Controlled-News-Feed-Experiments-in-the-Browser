DATABASE_URL="file:./dev.db"
APP_SECRET="change-me-to-a-long-random-string-in-production"
# Set true only after nginx/edge/Redis rate limits cover login and event APIs.
TRUSTED_RATE_LIMIT_PROXY="false"
# Set true for a public showcase. Admin writes are rejected server-side.
PUBLIC_DEMO_MODE="false"
ADMIN_EMAIL="admin@newslab.local"
ADMIN_PASSWORD="admin123"
# LLM generation — leave provider as "demo" to run with no API keys
LLM_PROVIDER="demo"
LLM_MODEL="claude-opus-4-8"
LLM_TEMPERATURE="0.3"
LLM_MAX_TOKENS="4096"
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
